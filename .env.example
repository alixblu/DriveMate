# Hugging Face — required for TimesFM model download on first startup
HUGGINGFACE_API_KEY=hf_...

# Alibaba Cloud DashScope — required for Qwen AI assistant chat
DASHSCOPE_API_KEY=sk-...

# Optional: Qwen model name (qwen-turbo is faster/cheaper for demos)
QWEN_MODEL=qwen-plus

# Optional: TimesFM tuning
TIMESFM_ENABLE_LIVE_FUEL=1
TIMESFM_FUEL_CONFIDENCE_THRESHOLD=78

# Optional: Assistant service tuning
ASSISTANT_TIMEOUT_S=30
ASSISTANT_MAX_TOKENS=512
